# Copy this file to .env and put your own key in it:
#
#     cp .env.example .env
#
# A free Groq key takes about a minute and needs no card: https://console.groq.com
#
# You do not need a key to run this project. The menu has already been read and the
# readings are committed in cache.json, so the app and the tests both work offline.
# You only need a key to re-read the menu yourself with `python extract.py`.
#
# A real GROQ_API_KEY environment variable overrides this file, so a deployed host
# or a CI runner does not need a .env at all.

GROQ_API_KEY=gsk_your_key_here
